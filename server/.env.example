# ─────────────────────────────────────────────────────────────────────────────
# Puzzle Suite Server — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
# Get from https://dashboard.stripe.com/webhooks after adding the endpoint
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Stripe Price IDs — create products/prices at https://dashboard.stripe.com/products
# Pro monthly recurring ($5/month)
STRIPE_PRICE_PRO_MONTHLY=price_REPLACE_ME
# Pro annual recurring ($45/year)
STRIPE_PRICE_PRO_ANNUAL=price_REPLACE_ME
# School monthly recurring ($49/month)
STRIPE_PRICE_SCHOOL_MONTHLY=price_REPLACE_ME
# Lifetime one-time ($99)
STRIPE_PRICE_LIFETIME=price_REPLACE_ME

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# Comma-separated list of allowed frontend origins (CORS)
ALLOWED_ORIGINS=http://localhost:8082,http://localhost:3000,https://YOUR_DOMAIN.com

# Long random string used to authenticate admin API requests.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# ── App URLs (used in Stripe redirect after checkout) ─────────────────────────
SUCCESS_URL=http://localhost:8082/puzzle-suite.html?checkout=success
CANCEL_URL=http://localhost:8082/puzzle-suite.html?checkout=cancel

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# For Gmail: use an App Password (https://myaccount.google.com/apppasswords)
# For other providers: adjust HOST/PORT accordingly
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Puzzle Suite <your@gmail.com>"
